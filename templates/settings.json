{
  "statusLine": {
    "type": "command",
    "command": "npx -y ccusage statusline"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/scripts/context-reinject.js" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/scripts/destructive-bash-guard.js" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/scripts/secret-leak-guard.js" },
          { "type": "command", "command": "node .claude/hooks/scripts/gitignore-warn.js" }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/scripts/exit-plan-autoapprove.js" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/scripts/auto-format.js" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/scripts/spec-awareness.js" },
          { "type": "command", "command": "node .claude/hooks/scripts/git-context.js" }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/scripts/transcript-backup.js" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/scripts/stop-notify.js" }
        ]
      }
    ]
  }
}
